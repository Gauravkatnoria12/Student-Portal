# ─── Required ─────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (free at mongodb.com/atlas — no credit card needed)
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/student-portal
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/student-portal

# Your deployed Vercel frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app

# ─── Local Dev Only ────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
